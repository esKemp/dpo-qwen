{
  // ---- LaTeX Workshop: build with latexmk (matches our verified CLI workflow) ----
  "latex-workshop.latex.recipe.default": "latexmk",
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk",
      "tools": ["latexmk"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-pdf",
        "-interaction=nonstopmode",
        "-synctex=1",
        "-file-line-error",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ],
      "env": {}
    }
  ],

  // ---- Send all build output (pdf + aux) to docs/build so the source folder stays clean ----
  "latex-workshop.latex.outDir": "%DIR%/build",

  // ---- Build automatically on save ----
  "latex-workshop.latex.autoBuild.run": "onSave",

  // ---- Preview the compiled PDF in an editor tab beside the source ----
  "latex-workshop.view.pdf.viewer": "tab"
}
